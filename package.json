{
  "name": "iptv-player",
  "version": "0.1.2",
  "description": "Lightweight open-source IPTV player for Windows",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "icons": "node scripts/generate-brand-assets.mjs && tauri icon static/brand/app-icon-1024.png -o src-tauri/icons && node scripts/patch-android-icon-bg.mjs",
    "fetch-mpv": "node scripts/fetch-mpv.mjs",
    "fetch-ffmpeg": "node scripts/fetch-ffmpeg.mjs",
    "generate-mpv-lib": "powershell -ExecutionPolicy Bypass -File scripts/generate-mpv-lib.ps1"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "@tauri-apps/cli": "^2"
  }
}
